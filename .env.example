# ────────────────────────────────────────────────────────────────────
#  RAG Lab — your settings.  (rag setup also fills the key in for you.)
# ────────────────────────────────────────────────────────────────────
#
#  Default LLM backend is Groq.
#  Get a FREE key:  https://console.groq.com  → API Keys → Create
#  Replace the placeholder below, save, then run:  rag info

GROQ_API_KEY=gsk_your_key_here

#  --- Prefer Hugging Face? (e.g. if Groq is blocked on your network) ---
#  Uncomment these three lines and add a free token from
#  https://huggingface.co/settings/tokens
#  RAG_LLM=hf
#  HF_TOKEN=hf_your_token_here
#  HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

#  Optional — override the model for the active backend:
#  RAG_MODEL=llama-3.3-70b-versatile
